# Defense-in-depth: prevent accidental commits if anyone runs `terraform` in a test source dir.
# (The framework normally copies user HCL into ~/.testframeworkv2/runs/<test>-<ts>/workdir/
# and runs there, so the source dir should stay clean. This .gitignore is just insurance.)

.terraform/
.terraform.lock.hcl
terraform.tfstate
terraform.tfstate.*
crash.log

# Framework-generated files
_tfv2_*.tf
_tfv2_*.json

# Local-build artifacts (if anything leaks)
local-version.json

# `make build` output. Anchored to testframeworkV2/ root so it doesn't
# accidentally match a subpath named tfv2 elsewhere in the tree.
/tfv2

# OS / editor noise.
.DS_Store
*.swp
*~
*.bak

# Local-only architecture doc — kept on disk, not in the repo.
/DESIGN.md
